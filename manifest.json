{
  "manifest_version": 3,
  "name": "微博助手与历史清理",
  "version": "1.0.0",
  "description": "微博发帖辅助 + 黑名单历史记录自动清理",
  "icons": {
    "16": "img/icon.png",
    "48": "img/icon.png",
    "128": "img/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://weibo.com/*"],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["tabs", "storage", "history"],
  "background": {
    "service_worker": "js/background.js"
  }
}
